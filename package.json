{
  "name": "@layervai/qurl-mcp",
  "version": "0.4.1",
  "description": "MCP server for qURL™ — secure link management for AI agents. Quantum URL is how you enter the hidden layer of the internet.",
  "mcpName": "io.github.layervai/qurl-mcp",
  "type": "module",
  "bin": {
    "qurl-mcp": "./dist/index.js",
    "qurl-mcp-http": "./dist/http.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck:tests": "tsc --project tsconfig.test.json",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "qurl",
    "layerv",
    "security",
    "ai-agents"
  ],
  "author": "LayerV AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/layervai/qurl-mcp"
  },
  "dependencies": {
    "@layervai/qurl": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/express": "^5.0.6",
    "@types/node": "20.19.43",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "assets/"
  ],
  "publishConfig": {
    "access": "public"
  }
}
